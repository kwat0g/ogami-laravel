APP_NAME="Ogami ERP"
APP_ENV=local
APP_KEY=
# !! CRITICAL — must be false in production !!
# APP_DEBUG=true leaks full stack traces, SQL queries, file paths, and config
# values in API error responses, exposing your server internals to attackers.
APP_DEBUG=true
APP_TIMEZONE=Asia/Manila
# Dev: http://localhost:8000 | Production: https://yourdomain.com
APP_URL=http://localhost:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_PH

# Controls Dockerfile build stage: "development" | "production"
APP_BUILD_TARGET=development

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ogami_erp
DB_USERNAME=ogami
DB_PASSWORD=secret
# NEVER set to true unless you put PgBouncer in front. Persistent connections
# keep a socket open per worker permanently and exhaust pg max_connections.
DB_PERSISTENT=false

# Test database — used by Pest (never the app DB)
TEST_DB_DATABASE=ogami_erp_test

SESSION_DRIVER=redis
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_PATH=/
# Dev: localhost | Production: .yourdomain.com  (leading dot covers apex + www)
SESSION_DOMAIN=localhost
SESSION_COOKIE=ogami_session
# Dev: false | Production: true  (required for HTTPS-only cookies)
SESSION_SECURE_COOKIE=false
# lax = safe default; protects CSRF for same-domain SPA + API
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=ogami_

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=secret
REDIS_PORT=6379
REDIS_PREFIX=ogami_erp_

# Sanctum
# Dev: localhost:5173,localhost:3000,localhost | Production: yourdomain.com,www.yourdomain.com
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000,localhost
SANCTUM_TOKEN_PREFIX=ogami_

# Laravel Reverb (WebSockets)
REVERB_APP_ID=ogami
REVERB_APP_KEY=your_reverb_key
REVERB_APP_SECRET=your_reverb_secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Laravel Horizon
HORIZON_DARK_MODE=false
HORIZON_MEMORY_LIMIT=256
HORIZON_PREFIX=
HORIZON_PATH=horizon

# Laravel Pulse
PULSE_ENABLED=true
PULSE_PATH=pulse
PULSE_STORAGE_KEEP="7 days"
PULSE_SLOW_QUERIES_THRESHOLD=500
PULSE_SLOW_JOBS_THRESHOLD=500
PULSE_SLOW_REQUESTS_THRESHOLD=1000

# Spatie Media Library
MEDIA_DISK=local

# Mail (adjust for production SMTP)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="erp@ogamimfg.local"
MAIL_FROM_NAME="${APP_NAME}"

# Spatie Backup
BACKUP_INCLUDE_FILES=false
BACKUP_ARCHIVE_PASSWORD=
BACKUP_NOTIFY_EMAIL="${MAIL_FROM_ADDRESS}"

# Backup
BACKUP_DISK=local
BACKUP_NAME="ogami-erp"

# Philippine region for minimum wage lookups (NCR default for dev)
DEFAULT_REGION=NCR

# Dashboard response caching (0 = disabled; see .env.production for recommended value)
DASHBOARD_CACHE_TTL=0
