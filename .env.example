APP_NAME="Ogami ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Manila
APP_URL=http://localhost:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_PH

APP_BUILD_TARGET=development
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ogami_erp
DB_USERNAME=ogami
DB_PASSWORD=secret
DB_PERSISTENT=false

TEST_DB_DATABASE=ogami_erp_test

SESSION_DRIVER=redis
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_COOKIE=ogami_session
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=ogami_

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=secret
REDIS_PORT=6379
REDIS_PREFIX=ogami_erp_

SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000,localhost
SANCTUM_TOKEN_PREFIX=ogami_

REVERB_APP_ID=ogami
REVERB_APP_KEY=ogami_reverb_key_local
REVERB_APP_SECRET=ogami_reverb_secret_local
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

HORIZON_DARK_MODE=false
HORIZON_MEMORY_LIMIT=256
HORIZON_PREFIX=
HORIZON_PATH=horizon

PULSE_ENABLED=true
PULSE_PATH=pulse
PULSE_STORAGE_KEEP="7 days"
PULSE_SLOW_QUERIES_THRESHOLD=500
PULSE_SLOW_JOBS_THRESHOLD=500
PULSE_SLOW_REQUESTS_THRESHOLD=1000

MEDIA_DISK=local

MFA_ISSUER="Ogami ERP"

MAIL_MAILER=log
MAIL_SCHEME=tls
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="erp@ogamimfg.local"
MAIL_FROM_NAME="${APP_NAME}"

BACKUP_INCLUDE_FILES=false
BACKUP_ARCHIVE_PASSWORD=
BACKUP_NOTIFY_EMAIL="${MAIL_FROM_ADDRESS}"
BACKUP_DISK=local
BACKUP_NAME="ogami-erp"

DEFAULT_REGION=NCR
DASHBOARD_CACHE_TTL=120
