  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "properties": {
          "email": {"type": "string", "format": "email", "example": "admin@ogamierp.local"},
          "password": {"type": "string", "format": "password", "example": "Admin@1234567890!"}
        },
        "required": ["email", "password"]
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": {"type": "string"},
          "user": {"$ref": "#/components/schemas/User"}
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "email": {"type": "string"},
          "roles": {"type": "array", "items": {"type": "string"}},
          "permissions": {"type": "array", "items": {"type": "string"}},
          "department_id": {"type": "integer", "nullable": true}
        }
      },
      "Employee": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "ulid": {"type": "string"},
          "employee_code": {"type": "string", "example": "EMP-2025-001"},
          "first_name": {"type": "string"},
          "last_name": {"type": "string"},
          "full_name": {"type": "string"},
          "date_of_birth": {"type": "string", "format": "date"},
          "gender": {"type": "string", "enum": ["male", "female", "other"]},
          "employment_type": {"type": "string", "enum": ["regular", "contractual", "project_based", "seasonal", "probationary"]},
          "employment_status": {"type": "string", "enum": ["active", "on_leave", "suspended", "resigned", "terminated"]},
          "pay_basis": {"type": "string", "enum": ["monthly", "daily", "hourly"]},
          "basic_monthly_rate": {"type": "integer", "description": "Amount in centavos"},
          "department_id": {"type": "integer", "nullable": true},
          "position_id": {"type": "integer", "nullable": true},
          "date_hired": {"type": "string", "format": "date"},
          "has_sss_no": {"type": "boolean"},
          "has_tin": {"type": "boolean"},
          "has_philhealth_no": {"type": "boolean"},
          "has_pagibig_no": {"type": "boolean"},
          "is_active": {"type": "boolean"},
          "created_at": {"type": "string", "format": "date-time"}
        }
      },
      "CreateEmployeeRequest": {
        "type": "object",
        "properties": {
          "first_name": {"type": "string", "maxLength": 100},
          "last_name": {"type": "string", "maxLength": 100},
          "date_of_birth": {"type": "string", "format": "date"},
          "gender": {"type": "string", "enum": ["male", "female", "other"]},
          "employment_type": {"type": "string", "enum": ["regular", "contractual", "project_based", "seasonal", "probationary"]},
          "pay_basis": {"type": "string", "enum": ["monthly", "daily", "hourly"]},
          "basic_monthly_rate": {"type": "integer", "description": "Amount in centavos"},
          "department_id": {"type": "integer"},
          "date_hired": {"type": "string", "format": "date"},
          "tin": {"type": "string", "pattern": "^\\d{3}-\\d{3}-\\d{3}-\\d{3}$", "nullable": true},
          "sss_no": {"type": "string", "pattern": "^\\d{2}-\\d{7}-\\d{1}$", "nullable": true},
          "philhealth_no": {"type": "string", "pattern": "^\\d{2}-\\d{9}-\\d{1}$", "nullable": true},
          "pagibig_no": {"type": "string", "pattern": "^\\d{4}-\\d{4}-\\d{4}$", "nullable": true}
        },
        "required": ["first_name", "last_name", "date_of_birth", "gender", "employment_type", "pay_basis", "basic_monthly_rate", "date_hired"]
      },
      "UpdateEmployeeRequest": {
        "type": "object",
        "properties": {
          "first_name": {"type": "string"},
          "last_name": {"type": "string"},
          "department_id": {"type": "integer"},
          "position_id": {"type": "integer"},
          "employment_status": {"type": "string"}
        }
      },
      "EmployeeTransitionRequest": {
        "type": "object",
        "properties": {
          "status": {"type": "string", "enum": ["active", "on_leave", "suspended", "resigned", "terminated"]},
          "reason": {"type": "string"},
          "effective_date": {"type": "string", "format": "date"}
        },
        "required": ["status"]
      },
      "EmployeeListResponse": {
        "type": "object",
        "properties": {
          "data": {"type": "array", "items": {"$ref": "#/components/schemas/Employee"}},
          "meta": {"$ref": "#/components/schemas/PaginationMeta"}
        }
      },
      "LeaveRequest": {
        "type": "object",
        "properties": {
          "leave_type_id": {"type": "integer"},
          "start_date": {"type": "string", "format": "date"},
          "end_date": {"type": "string", "format": "date"},
          "reason": {"type": "string"},
          "half_day": {"type": "boolean", "default": false}
        },
        "required": ["leave_type_id", "start_date", "end_date"]
      },
      "CreatePayrollRunRequest": {
        "type": "object",
        "properties": {
          "pay_period_id": {"type": "integer"},
          "department_ids": {"type": "array", "items": {"type": "integer"}},
          "run_type": {"type": "string", "enum": ["regular", "special", "13th_month", "final"]},
          "remarks": {"type": "string"}
        },
        "required": ["pay_period_id"]
      },
      "Vendor": {
        "type": "object",
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "tin": {"type": "string"},
          "is_ewt_subject": {"type": "boolean"},
          "is_active": {"type": "boolean"},
          "accreditation_status": {"type": "string", "enum": ["pending", "accredited", "suspended", "blacklisted"]},
          "contact_person": {"type": "string"},
          "email": {"type": "string"},
          "phone": {"type": "string"},
          "address": {"type": "string"},
          "bank_name": {"type": "string"},
          "bank_account_no": {"type": "string"},
          "payment_terms": {"type": "string"}
        }
      },
      "CreateVendorRequest": {
        "type": "object",
        "properties": {
          "name": {"type": "string", "maxLength": 255},
          "tin": {"type": "string", "pattern": "^\\d{3}-\\d{3}-\\d{3}-\\d{3}$", "nullable": true},
          "is_ewt_subject": {"type": "boolean", "default": false},
          "is_active": {"type": "boolean", "default": true},
          "contact_person": {"type": "string"},
          "email": {"type": "string", "format": "email"},
          "phone": {"type": "string"},
          "address": {"type": "string"},
          "bank_name": {"type": "string"},
          "bank_account_no": {"type": "string"},
          "bank_account_name": {"type": "string"},
          "payment_terms": {"type": "string"}
        },
        "required": ["name"]
      },
      "VendorListResponse": {
        "type": "object",
        "properties": {
          "data": {"type": "array", "items": {"$ref": "#/components/schemas/Vendor"}},
          "meta": {"$ref": "#/components/schemas/PaginationMeta"}
        }
      },
      "CreateCustomerRequest": {
        "type": "object",
        "properties": {
          "name": {"type": "string", "maxLength": 255},
          "tin": {"type": "string", "pattern": "^\\d{3}-\\d{3}-\\d{3}-\\d{3}$", "nullable": true},
          "email": {"type": "string", "format": "email"},
          "phone": {"type": "string"},
          "contact_person": {"type": "string"},
          "address": {"type": "string"},
          "credit_limit": {"type": "number", "default": 0},
          "is_active": {"type": "boolean", "default": true}
        },
        "required": ["name"]
      },
      "CreateJournalEntryRequest": {
        "type": "object",
        "properties": {
          "date": {"type": "string", "format": "date"},
          "description": {"type": "string"},
          "fiscal_period_id": {"type": "integer"},
          "lines": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "chart_of_account_id": {"type": "integer"},
                "debit_centavos": {"type": "integer"},
                "credit_centavos": {"type": "integer"},
                "description": {"type": "string"}
              },
              "required": ["chart_of_account_id"]
            },
            "minItems": 2
          }
        },
        "required": ["date", "description", "fiscal_period_id", "lines"]
      },
      "CreateItemRequest": {
        "type": "object",
        "properties": {
          "item_code": {"type": "string", "maxLength": 50},
          "name": {"type": "string", "maxLength": 255},
          "category_id": {"type": "integer"},
          "type": {"type": "string", "enum": ["raw_material", "semi_finished", "finished_good", "consumable", "spare_part"]},
          "unit_of_measure": {"type": "string"},
          "description": {"type": "string"},
          "reorder_point": {"type": "number"},
          "reorder_qty": {"type": "number"},
          "requires_iqc": {"type": "boolean", "default": false}
        },
        "required": ["item_code", "name", "category_id", "type", "unit_of_measure"]
      },
      "CreatePurchaseRequestRequest": {
        "type": "object",
        "properties": {
          "department_id": {"type": "integer"},
          "justification": {"type": "string"},
          "urgency": {"type": "string", "enum": ["normal", "urgent", "critical"], "default": "normal"},
          "required_date": {"type": "string", "format": "date"},
          "notes": {"type": "string"},
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "item_description": {"type": "string"},
                "unit_of_measure": {"type": "string"},
                "quantity": {"type": "number"},
                "estimated_unit_cost": {"type": "number"}
              },
              "required": ["item_description", "unit_of_measure", "quantity"]
            },
            "minItems": 1
          }
        },
        "required": ["department_id", "justification", "items"]
      },
      "PurchaseRequestListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {"type": "integer"},
                "ulid": {"type": "string"},
                "pr_reference": {"type": "string"},
                "department_id": {"type": "integer"},
                "status": {"type": "string"},
                "urgency": {"type": "string"},
                "justification": {"type": "string"},
                "total_estimated_cost": {"type": "string"},
                "created_at": {"type": "string"}
              }
            }
          },
          "meta": {"$ref": "#/components/schemas/PaginationMeta"}
        }
      },
      "PaginationMeta": {
        "type": "object",
        "properties": {
          "current_page": {"type": "integer"},
          "last_page": {"type": "integer"},
          "per_page": {"type": "integer"},
          "total": {"type": "integer"}
        }
      }
    },
    "securitySchemes": {
      "sanctum": {
        "type": "apiKey",
        "in": "cookie",
        "name": "ogami_session",
        "description": "Laravel Sanctum session cookie authentication"
      }
    }
  }
}
