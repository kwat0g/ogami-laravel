    "/hr/employees": {
      "get": {
        "tags": ["HR - Employees"],
        "summary": "List employees",
        "security": [{"sanctum": []}],
        "parameters": [
          {
            "name": "department_id",
            "in": "query",
            "schema": {"type": "integer"},
            "description": "Filter by department"
          },
          {
            "name": "employment_status",
            "in": "query",
            "schema": {"type": "string", "enum": ["active", "on_leave", "suspended", "resigned", "terminated"]},
            "description": "Filter by employment status"
          },
          {
            "name": "search",
            "in": "query",
            "schema": {"type": "string"},
            "description": "Search by name or employee code"
          }
        ],
        "responses": {
          "200": {
            "description": "List of employees",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmployeeListResponse"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["HR - Employees"],
        "summary": "Create employee",
        "security": [{"sanctum": []}],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateEmployeeRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Employee created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Employee"
                }
              }
            }
          }
        }
      }
    },
