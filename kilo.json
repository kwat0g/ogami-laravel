{
  "$schema": "https://app.kilo.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": true,
      "environment": {
        "NO_COLOR": "1",
        "NODE_NO_WARNINGS": "1"
      }
    },
    "socraticode": {
      "type": "local",
      "command": ["socraticode"],
      "enabled": true
    }
  }
}
