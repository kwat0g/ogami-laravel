#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# Ogami ERP — pre-push hook
# Runs automatically before every `git push`.
# Push is blocked if any check fails.
#
# Install (one-time):
#   git config core.hooksPath .githooks
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ok()   { echo -e "${GREEN}  ✔ $1${NC}"; }
fail() { echo -e "${RED}  ✘ $1${NC}"; }
info() { echo -e "${YELLOW}  → $1${NC}"; }

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "  Ogami ERP — pre-push checks"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""

ERRORS=0
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# ── 1. Laravel Pint (code style) ─────────────────────────────────────────────
if [ -f "$ROOT/vendor/bin/pint" ]; then
    info "Code style (Pint)..."
    if ./vendor/bin/pint --test --quiet 2>&1; then
        ok "Code style clean"
    else
        fail "Code style violations found — run: ./vendor/bin/pint"
        ERRORS=$((ERRORS + 1))
    fi
else
    info "Pint skipped (vendor/ not installed locally)"
fi

# ── 2. PHPStan (static analysis) ─────────────────────────────────────────────
if [ -f "$ROOT/vendor/bin/phpstan" ]; then
    info "Static analysis (PHPStan)..."
    if ./vendor/bin/phpstan analyse --no-progress --quiet 2>&1; then
        ok "PHPStan passed"
    else
        fail "PHPStan errors found — fix them before pushing"
        ERRORS=$((ERRORS + 1))
    fi
else
    info "PHPStan skipped (vendor/ not installed locally)"
fi

# ── 3. Frontend typecheck ─────────────────────────────────────────────────────
if [ -d "$ROOT/frontend" ]; then
    info "Frontend typecheck (TypeScript)..."
    if cd "$ROOT/frontend" && pnpm typecheck 2>&1; then
        ok "TypeScript types clean"
    else
        fail "TypeScript errors found — run: cd frontend && pnpm typecheck"
        ERRORS=$((ERRORS + 1))
    fi
    cd "$ROOT"
fi

# ── 4. Frontend lint (ESLint) ─────────────────────────────────────────────────
if [ -d "$ROOT/frontend" ]; then
    info "Frontend lint (ESLint)..."
    if cd "$ROOT/frontend" && pnpm lint 2>&1; then
        ok "No lint errors"
    else
        fail "ESLint errors found — run: cd frontend && pnpm lint"
        ERRORS=$((ERRORS + 1))
    fi
    cd "$ROOT"
fi

# ── Result ────────────────────────────────────────────────────────────────────
echo ""
if [ "$ERRORS" -gt 0 ]; then
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo -e "${RED}  ✘ Push blocked — $ERRORS check(s) failed.${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "  To skip checks (emergency only):"
    echo "    git push --no-verify"
    echo ""
    exit 1
fi

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo -e "${GREEN}  ✔ All checks passed — pushing.${NC}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo ""
